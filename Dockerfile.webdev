FROM node:22-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    wget \
    git \
    openssh-client \
    jq \
    ripgrep \
    fd-find \
    tree \
    less \
    unzip \
    zip \
    xz-utils \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    make \
    pkg-config \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && corepack enable \
    && npm i -g npm@latest typescript ts-node eslint prettier vite \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
